# ============================================
# GitHub Runner Configuration
# ============================================

# GitHub repository to register runners with (format: owner/repo)
# Example: myusername/myrepo
GITHUB_REPO=owner/repository

# Number of runner replicas to run (used by up.sh script)
RUNNER_REPLICAS=4

# Prefix for runner names (will append container hostname)
# Results in names like: myserver-runner-github-runners-github-runner-1, etc.
RUNNER_NAME_PREFIX=myserver-runner

# Runner architecture label (x64 or ARM64)
# Leave empty for automatic detection (recommended)
# The system will detect: x86_64 → x64, aarch64/arm64 → ARM64
# Only override if you need to force a specific architecture
RUNNER_ARCH=

# Personal Access Token - Create at: https://github.com/settings/tokens
# Required scopes: 'repo' and 'workflow'
# This will automatically generate fresh runner tokens as needed
# SECURITY: Never commit this token to git!
ACCESS_TOKEN=DO_NOT_TOUCH_THIS_PLACEHOLDER

# If you want to use docker actions
# Docker group ID from host system (run: getent group docker | cut -d: -f3)
DOCKER_GID=984

# ============================================
# Database Configuration (PostgreSQL)
# ============================================

# PostgreSQL password for cache database
# SECURITY: Use a strong password in production!
POSTGRES_PASSWORD=your_secure_postgres_password_here

# ============================================
# Storage Configuration (MinIO S3)
# ============================================

# MinIO admin credentials (S3-compatible storage)
# SECURITY: Use strong credentials in production!
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=your_secure_minio_password_here

# ============================================
# Nx Remote Caching Configuration (Optional)
# ============================================

# Nx Powerpack activation key for @nx/s3-cache plugin
# Obtain by running 'nx add @nx/s3-cache' in your Nx workspace
# The key is free and generated automatically during installation
# Leave empty if not using Nx caching
# SECURITY: This key is specific to your Nx installation and should not be shared
NX_KEY=

# ============================================
# Security Notes
# ============================================
# 1. Copy this file to .env: cp .env.example .env
# 2. Fill in your actual values (especially ACCESS_TOKEN)
# 3. Set restrictive permissions: chmod 600 .env
# 4. Never commit .env to version control (it's in .gitignore)
# 5. Use strong passwords for POSTGRES_PASSWORD and MINIO_ROOT_PASSWORD
# 6. Regularly rotate ACCESS_TOKEN and other credentials
